// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id       String   @id @default(uuid())
  name     String   @unique
  price    Float
  duration String
  duration_days Int?
  features String[]
  memberships Membership[]

  @@map("plans")
}

model Member {
  id            String       @id @default(uuid())
  name          String
  email         String?      @unique
  phone         String?
  date_of_birth DateTime?    @db.Date
  gender        String?
  join_date     DateTime     @default(now()) @db.Date
  created_by    String?
  created_at    DateTime     @default(now())

  memberships   Membership[]
  sessions      Session[]

  @@map("members")
}



model Membership {
  id         String         @id @default(uuid())
  member_id  String
  plan_id    String
  start_date DateTime       @db.Date
  end_date   DateTime       @db.Date
  status     String         @default("active")
  created_at DateTime       @default(now())

  member     Member         @relation(fields: [member_id], references: [id], onDelete: Cascade)
  plan       Plan           @relation(fields: [plan_id], references: [id])

  @@map("memberships")
}

model Trainer {
  id             String @id @default(uuid())
  name           String
  image          String
  specialization String
  experience     Int
  bio            String

  @@map("trainers")
}

model Transformation {
  id           String @id @default(uuid())
  member_name  String
  before_image String
  after_image  String
  description  String

  @@map("transformations")
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String
  role            String
  age             Int?
  gender          String?
  height          Float?
  weight          Float?
  fitness_goal    String?
  profile_picture String?
  created_at      DateTime @default(now())

  @@map("users")
}

model Session {
  id               String    @id @default(uuid())
  member_id        String
  check_in_time    DateTime
  check_out_time   DateTime?
  duration_minutes Int?
  created_at       DateTime  @default(now())

  member           Member    @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@map("sessions")
}
