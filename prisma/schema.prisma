// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id       String   @id @default(uuid())
  name     String   @unique
  price    Float
  duration String
  duration_days Int?
  features String[]
  memberships Membership[]

  @@map("plans")
}

model Member {
  id            String       @id @default(uuid())
  name          String
  email         String?      @unique
  phone         String?
  date_of_birth DateTime?    @db.Date
  gender        String?
  join_date     DateTime     @default(now()) @db.Date
  created_by    String?
  created_at    DateTime     @default(now())

  memberships   Membership[]
  sessions      Session[]
  weight_logs   WeightLog[]
  workout_logs  WorkoutLog[]
  workout_plans MemberWorkoutPlan[]

  @@map("members")
}



model Membership {
  id         String         @id @default(uuid())
  member_id  String
  plan_id    String
  start_date DateTime       @db.Date
  end_date   DateTime       @db.Date
  status     String         @default("active")
  created_at DateTime       @default(now())

  member     Member         @relation(fields: [member_id], references: [id], onDelete: Cascade)
  plan       Plan           @relation(fields: [plan_id], references: [id])

  @@map("memberships")
}

model Trainer {
  id             String @id @default(uuid())
  name           String
  image          String
  specialization String
  experience     Int
  bio            String

  @@map("trainers")
}

model Transformation {
  id           String @id @default(uuid())
  member_name  String
  before_image String
  after_image  String
  description  String

  @@map("transformations")
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String
  role            String
  age             Int?
  gender          String?
  height          Float?
  weight          Float?
  fitness_goal    String?
  profile_picture String?
  created_at      DateTime @default(now())

  @@map("users")
}

model Session {
  id               String      @id @default(uuid())
  member_id        String
  check_in_time    DateTime
  check_out_time   DateTime?
  duration_minutes Int?
  created_at       DateTime    @default(now())

  member           Member      @relation(fields: [member_id], references: [id], onDelete: Cascade)
  workout_log      WorkoutLog?

  @@map("sessions")
}

model Exercise {
  id           String              @id @default(uuid())
  name         String
  muscle_group String?

  workout_exercises WorkoutExercise[]
  exercise_logs     ExerciseLog[]

  @@map("exercises")
}

model WorkoutPlan {
  id         String        @id @default(uuid())
  name       String
  created_by String?
  created_at DateTime      @default(now())

  days       WorkoutDay[]
  assignments MemberWorkoutPlan[]

  @@map("workout_plans")
}

model WorkoutDay {
  id         String            @id @default(uuid())
  plan_id    String
  day_number Int
  title      String?

  plan       WorkoutPlan       @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  exercises  WorkoutExercise[]

  @@map("workout_days")
}

model WorkoutExercise {
  id          String      @id @default(uuid())
  day_id      String
  exercise_id String
  sets        Int?
  reps        String?

  day         WorkoutDay  @relation(fields: [day_id], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exercise_id], references: [id])

  @@map("workout_exercises")
}

model MemberWorkoutPlan {
  id          String      @id @default(uuid())
  member_id   String
  plan_id     String
  current_day Int         @default(1)
  assigned_at DateTime    @default(now())

  member      Member      @relation(fields: [member_id], references: [id], onDelete: Cascade)
  plan        WorkoutPlan @relation(fields: [plan_id], references: [id])

  @@map("member_workout_plans")
}

model Payment {
  id                  String   @id @default(uuid())
  member_id           String?
  plan_id             String?
  razorpay_order_id   String?
  razorpay_payment_id String?
  amount              Int
  status              String   @default("pending")
  created_at          DateTime @default(now())

  @@map("payments")
}

model WeightLog {
  id          String   @id @default(uuid())
  member_id   String
  weight      Float
  recorded_at DateTime @db.Date @default(now())
  created_at  DateTime @default(now())

  member      Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@map("weight_logs")
}

model WorkoutLog {
  id            String        @id @default(uuid())
  member_id     String
  session_id    String?       @unique
  workout_day   Int?
  day_title     String?
  created_at    DateTime      @default(now())

  member        Member        @relation(fields: [member_id], references: [id], onDelete: Cascade)
  session       Session?      @relation(fields: [session_id], references: [id])
  exercise_logs ExerciseLog[]

  @@map("workout_logs")
}

model ExerciseLog {
  id             String     @id @default(uuid())
  workout_log_id String
  exercise_id    String
  set_number     Int?
  reps           String?
  weight         Float?
  created_at     DateTime   @default(now())

  workout_log    WorkoutLog @relation(fields: [workout_log_id], references: [id], onDelete: Cascade)
  exercise       Exercise   @relation(fields: [exercise_id], references: [id])

  @@map("exercise_logs")
}
